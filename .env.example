# Flask
PORT=5000
FLASK_DEBUG=false

# MySQL / Aiven
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=28150
DB_USER=your_aiven_user
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb
DB_CONNECTION_TIMEOUT=10

# Optional: path to Aiven CA certificate if your deployment requires it.
# Example: DB_SSL_CA=/etc/secrets/ca.pem
DB_SSL_CA=

# SMTP email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SENDER_EMAIL=your_email@gmail.com
SMTP_SENDER_NAME=K-COFFEE

# QR payment
PAYMENT_PROVIDER=vietqr
PAYMENT_BANK_CODE=VCB
PAYMENT_ACCOUNT_NO=your_bank_account_number
PAYMENT_ACCOUNT_NAME=YOUR_ACCOUNT_NAME
ENABLE_MANUAL_PAYMENT_CONFIRM=false
